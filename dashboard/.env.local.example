# Single-password gate for the dashboard.
# Copy to .env.local for local dev; set the same vars in Vercel project settings for prod.

# The password Angus types to log in.
DASHBOARD_PASSWORD=change-me

# Random opaque token stored in the auth cookie. Rotate to invalidate all sessions.
# Generate: openssl rand -hex 32   (or any 32+ char random string)
DASHBOARD_SESSION_TOKEN=replace-with-long-random-string
